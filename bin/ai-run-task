#!/usr/bin/env bash
# ai-run-task — scaffold a new staged task run (v0.1).
#
# This is scaffolding ONLY. It does not edit code and does not call models.
# It creates a run directory, records the user's task, snapshots workspace
# status, and points you at the next command in the workflow.
#
# Usage:
#   ai-run-task "Short description of the task"

set -uo pipefail

TASK="${*:-}"

if [ -z "$TASK" ]; then
  echo "Usage: ai-run-task \"Short description of the task\"" >&2
  exit 2
fi

# Must be inside a git repo.
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ai-run-task must be run inside a git repository." >&2
  exit 1
fi
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# Build a filesystem-safe slug from the task text.
slug="$(printf '%s' "$TASK" \
  | tr '[:upper:]' '[:lower:]' \
  | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' \
  | cut -c1-40)"
[ -z "$slug" ] && slug="task"

TS="$(date +%Y%m%d-%H%M%S)"
RUN_DIR="$REPO_ROOT/.ai/runs/${TS}-${slug}"
mkdir -p "$RUN_DIR"

# 1) Save the user request.
cat > "$RUN_DIR/00-user-request.md" <<EOF
# User request

- Timestamp: $TS
- Repo: $REPO_ROOT
- Branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null)

## Task

$TASK
EOF

# 2) Snapshot workspace status.
if command -v ai-workspace-status >/dev/null 2>&1; then
  ai-workspace-status > "$RUN_DIR/01-workspace-status.txt" 2>&1 || true
else
  echo "ai-workspace-status not found on PATH" > "$RUN_DIR/01-workspace-status.txt"
fi

echo "Created run: $RUN_DIR"
echo "  - 00-user-request.md"
echo "  - 01-workspace-status.txt"
echo
echo "Next recommended step:"
echo "  1) Draft the plan with Opus 4.8 (high reasoning):"
echo "       ai-model-call plan   $RUN_DIR/plan-prompt.md   $RUN_DIR/02-plan.md"
echo "     (see templates/prompts/01-opus48-plan.md for the prompt to use)"
echo "  2) Then get a second opinion on the plan:"
echo "       ai-codex-review plan-review"
