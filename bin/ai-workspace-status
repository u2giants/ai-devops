#!/usr/bin/env bash
# ai-workspace-status — safety snapshot of the current git repo.
#
# Run inside a git repo. Shows repo path, branch, dirty/clean state, changed &
# untracked files, ahead/behind vs origin, latest commit, and (if gh can find
# one) the open PR URL. Warns loudly when on main/master or when the repo is
# dirty. Read-only: it never changes anything.

set -uo pipefail

# Load server.env for DEFAULT_MAIN_BRANCH if present (non-fatal).
SERVER_ENV="/etc/ai-devops/server.env"
DEFAULT_MAIN_BRANCH="main"
# shellcheck source=/dev/null
[ -f "$SERVER_ENV" ] && . "$SERVER_ENV" 2>/dev/null || true

c_head() { printf '\033[1m%s\033[0m\n' "$1"; }
c_warn() { printf '\033[33m⚠  %s\033[0m\n' "$1"; }

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Not inside a git repository." >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
BRANCH="$(git rev-parse --abbrev-ref HEAD)"

# True once the repo has at least one commit (avoids noisy errors on fresh repos).
HAS_COMMITS=0
git rev-parse --verify -q HEAD >/dev/null 2>&1 && HAS_COMMITS=1

c_head "Workspace status"
echo "Repo path : $REPO_ROOT"
echo "Branch    : $BRANCH"

# Dirty / clean
if [ -n "$(git status --porcelain)" ]; then
  echo "State     : DIRTY (uncommitted changes)"
  DIRTY=1
else
  echo "State     : clean"
  DIRTY=0
fi

# Changed (tracked) files
echo
c_head "Changed files (tracked)"
CHANGED="$(git status --porcelain --untracked-files=no | sed 's/^/  /')"
if [ -n "$CHANGED" ]; then echo "$CHANGED"; else echo "  (none)"; fi

# Untracked files
echo
c_head "Untracked files"
UNTRACKED="$(git ls-files --others --exclude-standard | sed 's/^/  /')"
if [ -n "$UNTRACKED" ]; then echo "$UNTRACKED"; else echo "  (none)"; fi

# Ahead / behind origin
echo
c_head "Sync with origin"
UPSTREAM=""
[ "$HAS_COMMITS" -eq 1 ] && UPSTREAM="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
if [ -n "$UPSTREAM" ]; then
  # counts: behind<TAB>ahead
  set -- $(git rev-list --left-right --count "${UPSTREAM}...HEAD" 2>/dev/null || echo "0 0")
  BEHIND="${1:-0}"; AHEAD="${2:-0}"
  echo "Upstream  : $UPSTREAM"
  echo "Ahead     : $AHEAD commit(s)"
  echo "Behind    : $BEHIND commit(s)"
else
  echo "No upstream tracking branch set for '$BRANCH'."
fi

# Latest commit
echo
c_head "Latest commit"
if [ "$HAS_COMMITS" -eq 1 ]; then
  git --no-pager log -1 --format='  %h  %s%n  by %an, %ar' 2>/dev/null
else
  echo "  (no commits yet)"
fi

# Open PR (best-effort via gh)
echo
c_head "Open PR"
if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
  PR_URL="$(gh pr view --json url --jq .url 2>/dev/null || true)"
  if [ -n "$PR_URL" ]; then
    echo "  $PR_URL"
  else
    echo "  (no open PR detected for this branch)"
  fi
else
  echo "  (gh not available or not authenticated — skipped)"
fi

# Warnings
echo
if [ "$BRANCH" = "$DEFAULT_MAIN_BRANCH" ] || [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  c_warn "You are on '$BRANCH' — create a feature branch before making changes."
fi
if [ "$DIRTY" -eq 1 ]; then
  c_warn "Working tree is DIRTY — commit, stash, or discard before switching context."
fi

exit 0
