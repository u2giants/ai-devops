#!/usr/bin/env bash
#
# Install the Claude skills and global system instructions from this repo onto
# the current machine, so every Claude Code session loads them automatically.
#
#   ai-install-skills            # install/refresh skills + global CLAUDE.md
#   ai-install-skills --dry-run  # show what would be copied
#
# - Skills:  skills/claude/<name>/  ->  ~/.claude/skills/<name>/
# - Global:  templates/system/CLAUDE-global.md -> ~/.claude/CLAUDE.md
#   (only if ~/.claude/CLAUDE.md is absent; otherwise prints a diff hint —
#   never clobbers local edits, same philosophy as install.sh)
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLAUDE_HOME="${CLAUDE_HOME:-$HOME/.claude}"
DRY_RUN="${1:-}"

run() { if [[ "$DRY_RUN" == "--dry-run" ]]; then echo "[dry-run] $*"; else "$@"; fi }

echo "Installing skills from $REPO_ROOT/skills/claude -> $CLAUDE_HOME/skills"
run mkdir -p "$CLAUDE_HOME/skills"
count=0
for d in "$REPO_ROOT"/skills/claude/*/; do
  name="$(basename "$d")"
  [[ -f "$d/SKILL.md" ]] || continue
  run rm -rf "$CLAUDE_HOME/skills/$name"
  run cp -a "$d" "$CLAUDE_HOME/skills/$name"
  count=$((count+1))
  echo "  + $name"
done
echo "$count skills installed."

install_global() {
  local src="$1" dst="$2" label="$3"
  if [[ ! -f "$dst" ]]; then
    run mkdir -p "$(dirname "$dst")"
    run cp "$src" "$dst"
    echo "Installed $label -> $dst"
    echo "NOTE: append this machine's section from templates/system/machine-atlas.md"
  elif cmp -s "$src" "$dst"; then
    echo "$label already up to date."
  else
    echo "$dst exists and differs (may contain machine-specific additions)"
    echo "— NOT overwriting. Compare with:  diff \"$dst\" \"$src\""
  fi
}

install_global "$REPO_ROOT/templates/system/CLAUDE-global.md" \
               "$CLAUDE_HOME/CLAUDE.md" "Claude global instructions"

# Codex (ChatGPT Codex CLI) reads ~/.codex/AGENTS.md the way Claude reads
# ~/.claude/CLAUDE.md. Install the Codex edition if Codex is set up here.
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
if [[ -d "$CODEX_HOME" ]]; then
  install_global "$REPO_ROOT/templates/system/AGENTS-global-codex.md" \
                 "$CODEX_HOME/AGENTS.md" "Codex global instructions"
else
  echo "No $CODEX_HOME directory — skipping Codex global instructions."
fi
