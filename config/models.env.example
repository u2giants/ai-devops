# ==========================================================================
# ai-devops model configuration (EXAMPLE)
# --------------------------------------------------------------------------
# install.sh copies this to /etc/ai-devops/models.env ONLY if that file does
# not already exist. Edit the REAL file at /etc/ai-devops/models.env to match
# the exact CLI flags available on THIS machine — the model flags below are a
# starting point and may differ on your system.
#
# This is an EXAMPLE file and is safe to commit. Never put tokens or secrets
# here — real secrets belong in the CLI login state (~/.claude, ~/.codex), not
# in this file.
# ==========================================================================

# Root of the toolkit checkout.
AI_DEVOPS_HOME="/worksp/ai-devops"

# --------------------------------------------------------------------------
# Model command overrides
# --------------------------------------------------------------------------
# Each variable is the FULL command used to invoke that stage's model. The
# scripts pipe a prompt to these commands. Adjust the flags to whatever your
# installed `claude` / `codex` CLIs actually accept (run `claude --help` /
# `codex --help` to confirm).

# Opus 4.8 with high reasoning — implementation planning & architecture,
# and the final product/architecture review.
OPUS48_HIGH_REASONING_CMD='claude --model opus-4.8 --reasoning high'

# Opus — independent reviewer used throughout (plan/diff/security/final).
OPUS_REVIEW_CMD='claude --model opus-4.8 --reasoning high'

# GPT-5.5 / Codex — implementation model (coding).
GPT55_CMD='codex exec --skip-git-repo-check'

# Codex — used by ai-codex-review for second-opinion reviews.
CODEX_CMD='codex exec --skip-git-repo-check'

# Tester — runs tests / visual checks / fixes (Codex-based by default).
TESTER_CMD='codex exec --skip-git-repo-check'
