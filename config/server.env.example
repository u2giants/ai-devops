# ==========================================================================
# ai-devops server configuration (EXAMPLE)
# --------------------------------------------------------------------------
# install.sh copies this to /etc/ai-devops/server.env ONLY if that file does
# not already exist. Edit the REAL file at /etc/ai-devops/server.env for this
# machine's specifics.
#
# This is an EXAMPLE file and is safe to commit. NEVER put tokens, secrets,
# passwords, or credentials in the real server.env either — this file is for
# non-secret, machine-local settings only.
# ==========================================================================

# Root of the toolkit checkout.
AI_DEVOPS_HOME="/worksp/ai-devops"

# Where per-machine config lives.
AI_DEVOPS_ETC="/etc/ai-devops"

# Log directory.
AI_DEVOPS_LOG_DIR="/var/log/ai-devops"

# Directory that holds your application repos (informational; onboarding later).
WORKSPACE_ROOT="/worksp"

# Default git "main" branch name for safety warnings (main or master).
DEFAULT_MAIN_BRANCH="main"

# Human name used in plain-English summaries produced by the final review.
OWNER_NAME="Albert"
