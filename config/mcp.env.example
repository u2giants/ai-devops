# ==========================================================================
# Central MCP secret references (EXAMPLE) — ONE source of truth for every app.
# --------------------------------------------------------------------------
# These are 1Password op:// REFERENCES, not secrets. It is safe to commit this
# file. The real secret values are never written here — they are resolved at
# launch by the vault-locked `op` service account (vault: vibe_coding ONLY).
#
# How it is used:
#   - Ubuntu / Claude Code:  the `claude` launcher runs
#         op run --env-file ~/.config/ai-devops/mcp.env -- claude
#     which fills the ${...} placeholders in each app's .mcp.json at launch.
#   - Windows / Claude Desktop: one mutex-protected `op run` refresh populates a
#     15-minute DPAPI-encrypted user cache shared by all MCP launchers.
#
# setup-secrets.sh (Ubuntu) / setup-windows.ps1 (Windows) copy this file to
#   ~/.config/ai-devops/mcp.env
# Add a new line here when any app introduces a new ${PLACEHOLDER}; every app
# and every machine then picks it up on the next launch. Never inline a value.
# ==========================================================================

# --- Active references (used by app .mcp.json files today) ----------------

# Supabase Personal Access Token — the ONE shared token for ALL POP apps
# (popdam, popcrm-web, poppim-web, monitor, hiclaw, ...). Do not create a
# per-app Supabase token; every app references this same item.
SUPABASE_ACCESS_TOKEN=op://vibe_coding/ujkouj7hatka2xyfbgvzyu4344/SUPABASE_ACCESS_TOKEN

# DesignFlow DevOps MCP (https://mcp.designflow.app/mcp) bearer token.
DEVOPS_MCP_TOKEN=op://vibe_coding/designflow-mcp/devops_token

# Synology monitor / NAS MCP (https://nas-mcp.designflow.app/mcp) bearer token.
NAS_MCP_TOKEN=op://vibe_coding/designflow-mcp/nas_token

# Trigger.dev account-level management PAT (item referenced by id to avoid the
# spaces in its title). Injected into the `trigger` MCP server (and the Ubuntu
# shell, enabling `npx trigger.dev@latest` CLI auth without interactive login).
TRIGGER_ACCESS_TOKEN=op://vibe_coding/zh3osi5w4lb2jdyuamcw3n4hw4/credential

# Recall.ai remote MCP (https://us-east-1.recall.ai/mcp) bearer token (item
# referenced by id to avoid the space in its title, "recall-ai MCP").
RECALL_AI_MCP_TOKEN=op://vibe_coding/6dqxnqdx2nwcuyeppvsb6nvkoq/password

# Z.ai GLM Coding Plan key. Used only by ai-glm-agent; the launcher injects it
# into an isolated Claude Code child process and never changes normal Claude or
# Codex authentication.
# Referenced by item id + FIELD id (item "GLM z.ai API"). Two traps this avoids:
#   1. The key is stored in the custom "api key" field (id vup42ni2phmssxqfkdfadxx22i),
#      NOT the item's built-in `credential` field, which is EMPTY. `op read`/`op run`
#      of an empty field return "" with exit 0 (a silent empty).
#   2. Item title and field label both contain spaces, which `op run --env-file`
#      mis-parses. Using the id form keeps the reference space-free.
# A silently-empty ZAI_API_KEY previously sent the launcher's re-exec into an
# infinite loop, so the launchers now fail loudly instead (see ai-glm-agent).
ZAI_API_KEY=op://vibe_coding/lc35ogs6lrvtjfsosathibgcwm/vup42ni2phmssxqfkdfadxx22i
ZAI_GLM_MODEL=glm-5.2
ZAI_ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# --- Available references (uncomment as an app adopts the placeholder) -----
# GitHub PAT with u2giants push access. Used for git push, not MCP; uncomment
# only if you want it injected into the Claude process environment too.
# GITHUB_TOKEN=op://vibe_coding/w6v3ddtuawl4l4lysgnzc3b5um/token
# GH_TOKEN=op://vibe_coding/w6v3ddtuawl4l4lysgnzc3b5um/token
