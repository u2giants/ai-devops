# ==========================================================================
# Managed SSH config (ai-devops) — host aliases for Albert's servers.
# --------------------------------------------------------------------------
# NON-SECRET (hostnames + the PUBLIC identity file path only). Safe to commit
# to this PRIVATE repo. Installed to ~/.ssh/config by the machine setup so
# `ssh vps` etc. work immediately on a new machine.
#
# Connectivity choice: hosts that have a Cloudflare tunnel use it as the PRIMARY
# path (ProxyCommand cloudflared). That path works on ANY network and IDENTICALLY
# on Windows and Linux, with no Tailscale required — the turnkey option for a new
# machine. (Power users who want the faster Tailscale mesh can switch a host's
# HostName to its 100.x Tailscale IP; those are noted per host.)
#
# All hosts authenticate with the 916-alien key, restored from 1Password by the
# setup script to ~/.ssh/916-alien. Requires: cloudflared installed (the setup
# script installs it).
# ==========================================================================

# GitHub — keeps its own separate key (git over SSH). Most git here uses HTTPS +
# the GitHub PAT, so this is only needed if you use SSH remotes.
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# Hetzner VPS / Coolify — the production server.
#   ssh vps   ssh vps2   ssh coolify   ssh hetzner
# (vps2 is an alias for the same box.) Tailscale IP: 100.66.37.58
Host vps vps2 coolify hetzner
    User root
    HostName ssh-coolify.designflow.app
    ProxyCommand cloudflared access ssh --hostname %h
    IdentityFile ~/.ssh/916-alien
    IdentitiesOnly yes
    ServerAliveInterval 30
    ServerAliveCountMax 3

# backupwiz — DigitalOcean droplet.  ssh backupwiz | ssh wiz
# Tailscale IP: 100.94.183.1
Host backupwiz wiz
    User root
    HostName ssh-backupwiz.designflow.app
    ProxyCommand cloudflared access ssh --hostname %h
    IdentityFile ~/.ssh/916-alien
    IdentitiesOnly yes
    ServerAliveInterval 60
    ServerAliveCountMax 120

# Seafile — Linode Seafile Pro server.  ssh seafile
# Tailscale IP: 100.92.1.120
Host seafile
    User ai
    HostName ssh-seafile.designflow.app
    ProxyCommand cloudflared access ssh --hostname %h
    IdentityFile ~/.ssh/916-alien
