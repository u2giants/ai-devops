# --- Hosts WITHOUT a Cloudflare tunnel (need Tailscale, or use the public IP) ---

# edgesynology1 — Synology NAS.  ssh edge1 | ssh edgesynology1
# Needs Tailscale (or LAN 192.168.3.100). Shown with its Tailscale IP.
Host edgesynology1 edge1
    User ahazan
    HostName 100.107.131.35
    IdentityFile ~/.ssh/916-alien
    IdentitiesOnly yes
    Port 22

# edgesynology2 — Synology NAS (admin SSH on port 1904).  ssh edge2 | ssh edgesynology2
Host edgesynology2 edge2
    User ahazan
    HostName 100.107.131.36
    IdentityFile ~/.ssh/916-alien
    IdentitiesOnly yes
    Port 1904

# Authentik server.  ssh auth | ssh authentik
# Tailscale 100.85.108.94:22, or public 47.110.86.216:1904.
Host auth authentik
    User root
    HostName 100.85.108.94
    IdentityFile ~/.ssh/916-alien
    IdentitiesOnly yes
    Port 22
    ServerAliveInterval 60
    ServerAliveCountMax 120

# AmneziaWG VPN server (public IP).  ssh vpn | ssh amnezia
Host vpn amnezia
    HostName 185.201.227.239
    User root
    IdentityFile ~/.ssh/916-alien
    IdentitiesOnly yes
